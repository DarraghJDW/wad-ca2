{{> menu}}

<section class="ui container">

  <div class="ui segment">

    <h2 class="ui header">{{title}}</h2>



    {{#each destinations}}

      <h3>{{name}}</h3>

      

      <p><b>Country:</b> {{country}}</p>
      <p><b>Description:</b> {{description}}</p>
      <p><b>Average Cost:</b> {{averageCost}}</p>
      <p><b>Best Season:</b> {{bestSeason}}</p>
      <img src="{{image}}" class="ui medium image">

      <hr>

    {{/each}}

  </div>

  <div class="ui segment">
  <form class="ui form" action="/collection/{{regionId}}/adddestination" method="POST">
    <div class="two fields">
      <div class="field">
        <input type="text" name="name" placeholder="Name" required>
      </div>
      <div class="field">
        <input type="text" name="country" placeholder="Country" required>
      </div>
    </div>
    <div class="field">
      <input type="text" name="description" placeholder="Description" required>
    </div>
    <div class="two fields">
      <div class="field">
        <input type="text" name="averageCost" placeholder="Average Cost" required>
      </div>
      <div class="field">
        <input type="text" name="bestSeason" placeholder="Best Season" required>
      </div>
    </div>
    <button class="ui blue submit button">Add Destination</button>
  </form>
</div>

</section>